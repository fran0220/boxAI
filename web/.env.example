# Local development for web/ (marketing + Creator)
# Copy to web/.env.local if needed.

# Backend for Vite proxy (default http://localhost:8080)
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Dev server port
VITE_DEV_PORT=5173

# Console origin for SSO / billing links (Vue app)
# Local: http://localhost:3000
# Production build: leave unset to auto-use https://console.you-box.com on you-box.com
VITE_CONSOLE_ORIGIN=http://localhost:3000

# API base for browser calls. Empty = same-origin (/api, /v1 via proxy or nginx)
# VITE_API_BASE=

# GitHub repo for desktop download assets
# VITE_DESKTOP_RELEASE_REPO=fran0220/boxAI

# Hosted Agent Gateway WebUI embedded by /app/agent (must be an absolute http(s) URL)
# VITE_AGENT_REMOTE_URL=https://api.you-box.com
