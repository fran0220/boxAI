# Local frontend → remote backend (production DB / Redis / API)
# Copy to .env.development.local (gitignored) and adjust if needed:
#
#   cp .env.development.local.example .env.development.local
#   pnpm dev
#   # or: pnpm dev:remote
#
# Browser talks to http://localhost:3000 only.
# Vite proxies /api /v1 /setup /health → VITE_DEV_PROXY_TARGET.
# Auth uses Bearer tokens in localStorage (no need to run local Postgres/Redis).

# Production BoxAI (youbox)
VITE_DEV_PROXY_TARGET=https://you-box.com

# Local Vite port (default 3000)
VITE_DEV_PORT=3000

# Keep relative API base so requests stay on the Vite origin and hit the proxy.
# Do NOT set this to https://you-box.com — that bypasses the proxy and hits CORS.
# VITE_API_BASE_URL=/api/v1

# Agentation visual feedback toolbar (dev-only React island)
# Optional MCP sync server: npx agentation-mcp server
# VITE_AGENTATION_ENDPOINT=http://localhost:4747
