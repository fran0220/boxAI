{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BoxAI Desktop",
  "version": "../package.json",
  "identifier": "com.boxai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 720,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["boxai-desktop"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczNjE4Q0Y5MkRGNkM2NUEKUldSYXh2WXQrWXhoYzhKT2lXbklEaUpXMGVCOXFSb3VkZWtDOEhNSGJITDBEMFROemdzK3owbzIK",
      "endpoints": []
    }
  }
}
